{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/llm-interop/task.schema.json",
  "title": "LLM interop task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "task_id", "source", "target", "hop_count", "mode", "permissions",
    "goal", "context", "constraints", "done_when", "deliverables"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "task_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$", "minLength": 1, "maxLength": 96},
    "source": {"type": "string", "minLength": 1},
    "target": {"type": "string", "minLength": 1},
    "hop_count": {"type": "integer", "minimum": 0, "maximum": 1},
    "mode": {"enum": ["research", "review", "implement"]},
    "permissions": {"enum": ["read-only", "workspace-write"]},
    "goal": {"type": "string", "minLength": 1},
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["files", "facts", "prior_decisions"],
      "properties": {
        "files": {"type": "array", "items": {"type": "string", "minLength": 1, "pattern": "^(?!/|~|[A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"}, "uniqueItems": true},
        "facts": {"type": "array", "items": {"type": "string"}},
        "prior_decisions": {"type": "array", "items": {"type": "string"}}
      }
    },
    "constraints": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "done_when": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1},
    "deliverables": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "description"],
        "properties": {
          "path": {"type": "string", "minLength": 1, "pattern": "^(?!/|~|[A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"},
          "description": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
