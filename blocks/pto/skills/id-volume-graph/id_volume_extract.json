{
  "nodes": [
    {"id": "tom", "label": "Том ИД", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§2,18", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Корень. Том исполнительной документации инженерной системы = N комплектов (каждый вокруг своего акта) + 3 сквозные прошивки (ПВ, Реестр-опись, Общий журнал работ) + орг.часть + титул. Состав диктуют Требования заказчика."},
    {"id": "komplekt", "label": "Комплект акта", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§18", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Базовая единица тома: один акт со своими приложениями. Внутри: Акт -> ведомость/Реестр-приложение -> исп.схемы -> документы качества этого этапа. ВСО входит в комплект только для АОМР (видимое оборудование); у АОСР-комплектов (скрытые работы) ВСО нет. ВОР (объёмы работ) — у КАЖДОГО акта, закрывающего работы: и АОМР, и все АОСР (живёт на ИС, ≡ ВСО там, где ВСО есть). АОУСИТО и акты испытаний работы не закрывают — без ВОР и без ВСО."},
    {"id": "pv", "label": "Предъявительская ведомость (ПВ)", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§18,21", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Сквозная прошивка №1 и ГЛАВНЫЙ (master) список всего оборудования/материалов тома. Каждая позиция -> № акта + дата + примечание(помещение). Происходит из спецификации РД + фактические изменения, видимые на ИС. ВСО и ВОР — её проекции по актам/работам."},
    {"id": "reestr_opis", "label": "Общий Реестр-опись", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§6,21", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Сквозная прошивка №2. Оглавление всего тома с накопительной нумерацией листов G[n]=F[n-1]+G[n-1]. Идёт обложкой-вкладышем, в число листов тома не входит. Страницы — по факту печати."},
    {"id": "zhurnal_rabot", "label": "Общий журнал работ", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§18,20", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Сквозная прошивка №3 (в хвосте тома). Хронология работ по датам; акт освидетельствует этап по дате журнала. Первичная хронология."},
    {"id": "org_chast", "label": "Орг.часть (приказы + СРО)", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§1,2", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Приказы о назначении ответственных + выписки СРО. Блок повторяется в каждом томе, но приказы привязаны к подписантам конкретных актов: акты разных лет -> у лица разные приказы."},
    {"id": "prikaz", "label": "Приказ о назначении", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§26", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Документ полномочий подписанта акта. Правило: дата приказа <= даты акта (нельзя ссылаться на приказ позже акта); среди приказов лица берём последний по дате <= акта; при смене меняем И номер, И дату вместе."},
    {"id": "vypiska_sro", "label": "Выписка СРО", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§2", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Выписка из реестра СРО организаций (генподряд + субподряд). Стандартный блок орг.части."},
    {"id": "titul", "label": "Титульный лист", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§7", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Голова тома. При смене тома меняется только строка шифра работ; остальное идентично."},

    {"id": "akt", "label": "Акт (общий)", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§3,4,19", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Ядро комплекта, освидетельствует этап работ. Ключевые поля: тип, №, даты начала/окончания работ, локация (оси/отметка ИЛИ помещение, не оба), подписанты со своими приказами, нормы п.6. Гранулярность (что объединять/дробить — труба+изоляция, посистемно) — по требованию заказчика, не зашита."},
    {"id": "akt_aosr", "label": "АОСР (скрытые работы)", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§3,19", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Акт освидетельствования скрытых работ (внутри конструкций: монтаж трубопровода, теплоизоляция, заделка узлов прохода). Норм.база — Постановление 470 + профильный СП. п.7 «разрешается» открывает следующий этап монтажа."},
    {"id": "akt_aomr", "label": "АОМР (монтаж оборудования)", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§3,19", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Акт об окончании монтажных работ — сдача видимого смонтированного оборудования (сантехника, оборудование). СП 73.13330. К нему — ВСО (суффикс шифра .1)."},
    {"id": "akt_aousito", "label": "АОУСИТО (главный акт)", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§19", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Акт освидетельствования участков сетей ИТО. Главный/агрегирующий акт тома (требование заказчика): ссылается на все акты (-1/-3/-4/-5) + протоколы испытаний, несёт сводку по тому. Имеет свои общие схемы (отдельные от детальных ИС)."},
    {"id": "protokol_ispytaniy", "label": "Протоколы испытаний", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§23,25", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Акт гидравлических испытаний на герметичность + акт промывки/продувки (для хоз-питьевого В1 промывка обязательна по СП 73.13330, отдельно от гидроиспытания). Прикладываются к АОУСИТО. Дезинфекция/пролив — по требованию заказчика (бывает на утверждении)."},

    {"id": "reestr_n", "label": "Реестр №X (приложение к акту)", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§21", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Опись материалов/документов качества ПОД конкретный акт. Колонки: №|Тип документа|Номер|Дата|Кол-во листов|Шифр чертежа. Включается, когда материалы и их документы переполняют 2-страничную (лицо/оборот) вёрстку акта (перелив на 3-ю страницу). Чужой шифр в реестре — опечатка, исправлять."},
    {"id": "is_detail", "label": "Исполнительная схема (ИС)", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§20; ИС-цвет", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Детальная схема ПОД конкретный акт (один вид работ). Позиции акта — в цвете (выноски к ним чёрные), контекст (трубы/оборуд. для привязки) — серым. ИС 1:1 со своим актом (имя схемы = наименование работ акта), не шарится между актами. Первоисточник количеств; ИС ≡ ВОР (инвариант)."},
    {"id": "obshie_shemy", "label": "Общие схемы (АОУСИТО)", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "правка пользователя", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Сводные схемы в комплекте АОУСИТО: показано всё что в РД, но с фактическими изменениями; без мелких деталей (гильзы/размеры). Отдельны от детальных ИС актов. (методичка §26 ошибочно писала о шаринге схем между актами — неверно)."},
    {"id": "vso", "label": "ВСО (вед. смонтир. оборудования)", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§5; ВСО формат", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Проекция ПВ по смонтированному оборудованию; приложение к АОМР (суффикс шифра .1). Шапка: №|Наименование|Тип,марка|Завод-изготовитель|Кол-во|Примечание(№ помещений). Бренд/модель НЕ в «Наименование» (модель -> Тип,марка; изготовитель -> Завод)."},
    {"id": "vor", "label": "ВОР (вед. объёмов работ)", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§26; ИС-ВОР", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Проекция ПВ по объёмам работ (по актам). Есть у КАЖДОГО акта, закрывающего работы (АОМР + все АОСР), не только у АОСР; живёт на ИС, должна быть равна ИС и соответствовать ВСО (там, где ВСО есть). АОУСИТО и акты испытаний — без ВОР. Промежуточный xlsx-ВОР может устаревать — при расхождении приоритет у чертежа/ИС; xlsx помечать как требующий обновления."},
    {"id": "specifikaciya_rd", "label": "Спецификация РД/СО", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§1.8 (06-06)", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Проектная спецификация оборудования (раздел СО) — главный первоисточник наименований/артикулов/количеств. Из неё (+ фактические изменения, видимые на ИС) рождается ПВ."},

    {"id": "poziciya", "label": "Позиция (оборуд./материал)", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§1.8,26", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Единица состава (оборудование/материал/арматура): наименование/артикул/кол-во/помещение. Наименование — из спецификации РД и/или ИС, не из головы; артикул — проверяемый идентификатор, сверять по каталогу. Любая позиция тянет требование документа качества на неё."},
    {"id": "dok_kachestva", "label": "Документ качества", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§24,26; инвентарь", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Подтверждение позиции. Обобщённо «паспорт» = любая документация (паспорт/тех.паспорт/РЭ/инструкция). Требование закрывается одним из взаимозаменяемых типов (СС / декларация ЕАЭС / инф.письмо / отказное). Инвентарь строить ОТ собранного PDF тома (часто вшиты/названы произвольно), а не от папки «Паспорта». Правило дат: документ качества должен быть действителен на ДАТУ АКТА — срок релевантен относительно даты акта, не абсолютно (для разных актов один документ может годиться или нет); истёкший на дату акта = разрыв (ТН вернёт). Привязка факта монтажа: позиция -> акт; задача увязки документ->позиция->акт — у системы ведения ИД, в ручной практике документ просто подшит за актом."},
    {"id": "pasport", "label": "Паспорт / РЭ / инструкция", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§24", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Документация производителя на позицию. Считается по числу PDF-страниц."},
    {"id": "ss", "label": "Сертификат соответствия (СС)", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§24", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Сертификат соответствия. Может заменяться декларацией ЕАЭС / инф.письмом / отказным, если СС не требуется/нет."},
    {"id": "deklaraciya_eaes", "label": "Декларация ЕАЭС", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§24", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Декларация о соответствии. Имеет срок действия — просроченная не годится (типовой разрыв ТН)."},
    {"id": "inf_pismo", "label": "Информационное письмо", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§24", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Информационное письмо (напр. о применимости/необязательности сертификации). Допустимая замена СС."},
    {"id": "otkaznoe", "label": "Отказное письмо", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§24", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Письмо о необязательности сертификации позиции. Допустимая замена СС."},
    {"id": "garant_talon", "label": "Гарантийный талон", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "замечание п.15", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Гарантийный талон в паспорте; должен быть заполнен поставщиком (типовой разрыв: не заполнен)."},

    {"id": "zamechanie", "label": "Замечание ТН", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§24", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Указывает на разрыв между требованием заказчика и фактом тома. Источник двойной: официальный список пунктов + карандашные пометки/стикеры на листах (фото/видео). ТН — человек, может ошибаться/пропускать -> проверять замечание на адекватность. Есть категория «наше, но не по нашей вине» (не выпущена актуальная РД, физика не готова) — исправить нельзя. Реестр замечаний: №|суть|решение|статус|тип; пункты делятся наши/не-наши(исключённые)/ждут данных."},
    {"id": "razryv_net_dok", "label": "Разрыв: нет акта/документа", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§24", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Требование заказчика есть, а акта/документа в томе нет (нет акта дезинфекции; нет СС/паспорта на трубы PEX)."},
    {"id": "razryv_nepolnaya_vso", "label": "Разрыв: неполная ВСО/схема", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§24", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Позиция смонтирована по факту, но не включена в ВСО/ВОР/схему (сифоны, гибкие подводы, угловой кран)."},
    {"id": "razryv_shema_bez_dlin", "label": "Разрыв: схема без длин/арматуры", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§24", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "На исп.схеме не указаны длины участков, места изменения диаметра, запорная арматура/компенсаторы, условные обозначения (прямое требование заказчика к схемам АОСР коммуникаций)."},
    {"id": "razryv_dok_ne_fakt", "label": "Разрыв: документ не соответствует факту", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§24", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Документ качества не соответствует фактически смонтированному (фирма по проекту vs факту, грувлок vs сварка, просроченный/незаверенный сертификат, лишний сертификат на непримененный диаметр)."},
    {"id": "razryv_norm_ssylka", "label": "Разрыв: нормативная ссылка в акте", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§26", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "В п.6 акта недостаёт нужного СП/ГОСТ (для ВиВ — нужны оба СП 73.13330.2016 + СП 30.13330.2020)."},
    {"id": "razryv_rekvizity", "label": "Разрыв: реквизиты", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§26", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Неверные реквизиты приказа подписанта (дата приказа позже акта; б/н вместо номера) или должность тех.заказчика указана не полностью как в приказе."},
    {"id": "norma", "label": "Норма (СП/ГОСТ/Постановление)", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§26", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Нормативная ссылка в п.6 акта. Только через norm-lookup, не по памяти. Для ВиВ — оба СП 73.13330.2016 (монтаж/приёмка) + СП 30.13330.2020 (проектирование); иногда хватает одного (зависит от ТН)."},
    {"id": "trebovaniya_zakazchika", "label": "Требования заказчика (! Требования к ИД)", "file_type": "concept", "source_file": "Обучение составления ИД.md", "source_location": "§23", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Корневой норматив состава ИД (официальный перечень по группам систем). Полный пакет инж.системы: АОМР + ВСО + документы качества + ИС оборудования + АОУСИТО + итоговые схемы + промывка/продувка + гидроиспытания + дезинфекция ХВС/ГВС + АОСР узлов прохода/гильз + АОСР опор + АОСР прокладки коммуникаций + АОСР антикор/заделка/теплоизоляция + индивид.испытания + ПНР + паспорт системы. От него считаются разрывы (замечания ТН). Локальные изменения бывают. Читать первым по комплектности."},

    {"id": "inv_soglasovannosti", "label": "Инвариант: ПВ ≡ ВСО ≡ ВОР ≡ ИС", "file_type": "rationale", "source_file": "Обучение составления ИД.md", "source_location": "правка пользователя", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Все ведомости и схема должны быть согласованы (равны). ПВ — master список; ВСО и ВОР — её проекции по актам/работам; ИС = ВОР. Нарушение равенства = разрыв = замечание ТН по составу."},
    {"id": "kaskad", "label": "Каскад изменений", "file_type": "rationale", "source_file": "Обучение составления ИД.md", "source_location": "§26 (фундаментальный)", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Любая правка состава тянет цепочку: Акт -> Реестр №X -> ВОР -> ВСО -> ПВ -> Реестр-опись -> таблицы/выноски на исп.схемах (DWG). Не править изолированно. Вести журнал каскадных правок; добавленная позиция тянет и требование её документа качества."},
    {"id": "fakt_pervichen", "label": "Факт первичен", "file_type": "rationale", "source_file": "Обучение составления ИД.md", "source_location": "07-06 методология", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "При разборе замечания сначала смотреть собранный PDF тома + ИС (актуально ли замечание — могло быть закрыто), потом править. Количества — по чертежу/ИС, не по устаревшему xlsx-ВОР. Метод подсчёта позиций — лучше по PDF, НЕ финализирован, возможно свой под каждый раздел."},
    {"id": "dvustoronnyaya_pechat", "label": "Двусторонняя печать / нумерация листов", "file_type": "rationale", "source_file": "Обучение составления ИД.md", "source_location": "§22", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Акт/ВСО/АОСР печатаются двусторонне -> 1 лист = 2 страницы PDF; № листа тома ≠ № страницы PDF. Реестры/ПВ не обязательно двусторонние. Паспорта и прочее считаются по числу PDF-страниц. У акта фиксированный порядок лицевой/обратной части (перелив материалов -> Реестр №X)."},
    {"id": "ne_vydumyvat", "label": "Не выдумывать; артикул по каталогу", "file_type": "rationale", "source_file": "Обучение составления ИД.md", "source_location": "§11,26; правка пользователя", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Claude ничего не называет по памяти/выдумке — только при уверенности из первоисточника. Артикул = проверяемый идентификатор (сверять по каталогу производителя). Распознанная рукопись ТН и запись прошлой сессии — НЕ истина. Нет данных -> «—»/«проверить»/спросить. По любому решению — утверждаться у пользователя."},
    {"id": "unifikaciya", "label": "Унификация по строениям", "file_type": "rationale", "source_file": "Обучение составления ИД.md", "source_location": "§1.7", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Разделы по строениям одинаковые, оборудование часто совпадает -> недостающие наименования/документы качества брать из ИД того же раздела другого строения + проектная спецификация. Финальное решение — за пользователем."},
    {"id": "peresborka_pdf", "label": "Пересборка PDF в конце", "file_type": "rationale", "source_file": "Обучение составления ИД.md", "source_location": "§26", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Правки вносятся только в исходники; собранный PDF тома — производный, не правится по ходу. Когда все замечания закрыты — одна пересборка + пересчёт реестра-описи (нумерация листов плывёт от исключений/доборов). Вести список изменённых листов/актов/страниц (что перепечатать/выкинуть/заменить). Исходную версию «как сдано в ТН» не затирать; новая — с новой датой."},
    {"id": "data_link_net", "label": "Data Link (ушли от него)", "file_type": "rationale", "source_file": "Обучение составления ИД.md", "source_location": "§26", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Таблицы ВОР/спецификаций в DWG: Data Link был и где-то есть, но ушли от него (неудобно). Как правило таблицы вставлены статично -> после правки xlsx таблицу в DWG перевставляет человек вручную (агент не может). Вести список «какая таблица — в каком DWG/листе»."},
    {"id": "gruntovka_ocinkovka", "label": "Грунтовка на оцинковке не нужна", "file_type": "rationale", "source_file": "Обучение составления ИД.md", "source_location": "§26", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Общее правило монтажа/ГОСТ: на оцинкованных трубах антикор-грунтовка (и АОСР грунтовки) не делается; на чёрной стали — нужна."}
