# =====================================================================
# WHITELIST .gitignore для ~/.claude/ как git-репозитория
# =====================================================================
#
# СТРАТЕГИЯ: игнорируем ВСЁ, кроме явно разрешённых директорий и файлов.
# Это защищает от случайного попадания в git:
#   - .credentials.json (auth-токены Anthropic — компрометация аккаунта)
#   - history.jsonl (полные логи чатов — конфиденциальные данные клиентов)
#   - cache/, downloads/, plugins/, backups/, file-history/, projects/
#   - _sandbox/ (локальные тесты внешнего кода)
#
# Если появится новая директория, которую нужно версионировать —
# явно добавить её в whitelist ниже. Без явного добавления — игнорируется.
# =====================================================================

# Игнорируем всё
*

# Кроме самого .gitignore
!.gitignore

# Корневые файлы базы
!CLAUDE.md
!README.md
!CHANGELOG.md
!mcp-manifest.json
!Карта vault.md
# NOTE: settings.json теперь gitignored (см. ниже Phase 1 sync-redesign),
# settings.shared.json в репо вместо него:
!settings.shared.json
!anti-patterns.md
# Scope-фильтр графа знаний (читается graphify detect, раздаётся команде)
!.graphifyignore

# Auto-sync скрипты (запускаются Claude Code как hooks)
!scripts/
!scripts/**

# Структура агентов / скиллов / команд (рекурсивно)
!agents/
!agents/**

!skills/
!skills/**

!commands/
!commands/**

# Эмпирическая память (наша аналитика, не Claude Code'овская)
!memory/
!memory/**

# Per-session отчёты (НАШИ — обезличенные разборы реальных задач)
# ВАЖНО: имя session-reports/, не sessions/. ~/.claude/sessions/ Claude
# Code использует для своих transient JSON-файлов состояния сессии —
# их в git тащить нельзя.
!session-reports/
!session-reports/**

# Каталог harvest (notes-only)
!harvested/
!harvested/**

# Шаблоны оформления документов (DOCX — стили ГОСТ 7.32 + plain-clean)
# Бинарные, но небольшие (~140-220 KB каждый); общие на все ПК
!formatting-templates/
!formatting-templates/**

# Именованные цепочки (chains) — импорт из аудита <организация> 2026-05-20
# First-class сущность оркестратора. См. chains/README.md.
!chains/
!chains/**

# Доменные блоки с активацией по роли (см. blocks/README.md)
!blocks/
!blocks/**

# Regression-тесты (pytest) для скиллов — импорт из аудита <организация> 2026-05-20
# См. evals/README.md
!evals/
!evals/**

# Дизайн-спецификации (output из superpowers:brainstorming skill).
# Каждая крупная задача → spec в docs/superpowers/specs/YYYY-MM-DD-<topic>-design.md
!docs/
!docs/**

# Локальная библиотека норм (knowledge library) — INDEX + categories + README.
# Сами PDF лежат на Я.Диске, в git только метаданные/индекс/аннотации.
# См. docs/superpowers/specs/2026-05-26-knowledge-library-design.md
!library/
!library/**

# _sandbox/ есть в репо как папка с README, но содержимое НЕ пушится
!_sandbox/
!_sandbox/README.md
_sandbox/*
!_sandbox/README.md

# =====================================================================
# Hard blocks: эти паттерны ВСЕГДА игнорируются, даже если случайно
# попали в whitelisted-директорию (защита от человеческой ошибки)
# =====================================================================

# Auth tokens — критично
**/.credentials.json
**/credentials.json
**/.env
**/.env.*

# История чатов / runtime — критично
**/history.jsonl
**/conversation-*.json

# Локальные настройки конкретного ПК
**/settings.local.json

# Per-PC configs с secrets / per-machine путями (никогда в git)
**/.feedback-config.json
**/.library-config.json
**/.developer-marker

# settings.json — gitignored с 2026-05-21 (Phase 1 sync-redesign).
# Причина: Claude Code UI пишет туда сам (theme, viewMode, editorMode и т.п.),
# что вызывало постоянные merge conflict'ы между ПК. Теперь UI пишет в
# personal local file, а shared values (autoMode/language/effortLevel/plugins/hooks)
# лежат в settings.shared.json и вливаются в local через
# scripts/merge-shared-settings.ps1 при auto-pull.
settings.json
**/settings.json
# Но settings.shared.json — наоборот, в репо (это и есть team-shared):
!settings.shared.json

# Активационные копии агентов блоков (создаёт /sync-base per-PC; источник — blocks/)
agents/block-*.md

# Auto-sync лог (per-PC, append-only, не должен лететь в git)
**/auto-sync.log

# Per-machine local state (markers что setup-extras применён, etc.)
# Содержимое отслеживает локальное состояние конкретного ПК,
# не должно попадать в общую базу.
.local-state/
**/.local-state/

# Claude Code transient session state (создаётся самим Claude Code)
# в ~/.claude/sessions/ — конфликтует с нашим прежним sessions/.
# Сейчас наша папка переименована в session-reports/, но на всякий
# случай явно игнорируем sessions/ если она появится.
sessions/
**/sessions/

# Бинарные мусор-файлы
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache/
**/.DS_Store
**/Thumbs.db
**/desktop.ini

# IDE
.idea/
.vscode/
*.sublime-workspace

# Obsidian (если используется как vault)
.obsidian/

# Рабочая область ИД-сессии — необезличенное сырьё, НЕ пушить в claude-base
work/

# graphify generated output
graphify-out/

# === Исключение (2026-06-09): граф САМОЙ БАЗЫ — деливерабл, версионируется ===
# Правило `graphify-out/` выше продолжает игнорировать графы в подпапках
# (build-output проектов). Корневой граф базы разъезжается по всем ПК через git;
# хаб актуализирует его при правках базы (см. CLAUDE.md секция graphify).
!/graphify-out/
/graphify-out/*
!/graphify-out/graph.json
!/graphify-out/.graphify_labels.json
!/graphify-out/GRAPH_REPORT.md

# Фирменный бланк с реквизитами — НЕ раздавать (правило 6)
skills/word-helper/templates/*.docx

# =====================================================================
# Локальные дизайн-скиллы (UI UX Pro Max комплект, github nextlevelbuilder)
# Установлены 2026-06-26 ТОЛЬКО на хаб (DANIILPC) для Claude Design.
# НЕ раздавать в базу. Перебивают whitelist !skills/** выше (последнее правило выигрывает).
# =====================================================================
skills/ui-ux-pro-max/
skills/design/
skills/design-system/
skills/ui-styling/
skills/brand/
skills/slides/
skills/banner-design/

# durable-лог эскалаций прораба (локальный, команды воркеров — не в git)
skills/supervisor/tools/supervisor-escalations.log
supervisor-escalations.log
