{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "& \"$HOME\\.claude\\scripts\\auto-pull.ps1\"",
            "shell": "powershell",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "& \"$HOME\\.claude\\scripts\\auto-pull.ps1\"",
            "shell": "powershell",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
